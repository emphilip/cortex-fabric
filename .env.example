# --- Identity stub (v0 — REPLACE BEFORE PROD) -------------------------------
CORTEX__IDENTITY__PRINCIPAL=local-dev
CORTEX__IDENTITY__ROLES=admin,reader
CORTEX__TENANT=default

# --- Storage ----------------------------------------------------------------
CORTEX__POSTGRES__URL=postgresql://cortex:cortex@postgres:5432/cortex
CORTEX__QDRANT__URL=http://qdrant:6333
CORTEX__VALKEY__URL=redis://valkey:6379/0

# --- Model providers --------------------------------------------------------
# The v0 stack ships its own Ollama service in compose at http://ollama:11434.
# The configured embedding model is pulled on first start of that container.
CORTEX__OLLAMA__BASE_URL=http://ollama:11434
CORTEX__OLLAMA__EMBEDDING_MODEL=nomic-embed-text

# Optional alternatives (uncomment + set as needed):
#   * Host Ollama via Docker Desktop:    http://host.docker.internal:11434
#   * Ollama Cloud (chat-only in v0):    https://ollama.com   (see note below)
# CORTEX__OLLAMA__BASE_URL=http://host.docker.internal:11434

# Ollama Cloud API key. The thin MVP does NOT use Cloud for embeddings — Cloud
# gates /api/embed on the reference account (see
# openspec/changes/bootstrap-thin-mvp/design.md D1). The key is reserved for
# follow-up changes that introduce chat / intent / generation paths.
# SECRET — never commit.
# CORTEX__OLLAMA__API_KEY=

# The graph extractor uses an independently configurable Ollama chat endpoint.
# Keep the key in `.env`; never place it in cortex.yaml.
CORTEX__PROVIDERS__CHAT__BASE_URL=https://ollama.com
CORTEX__PROVIDERS__CHAT__MODEL=gemma3:4b
# CORTEX__PROVIDERS__CHAT__API_KEY=

# Best-effort text extraction controls.
CORTEX__PROVIDERS__EXTRACTION__ENABLED=true
CORTEX__PROVIDERS__EXTRACTION__MIN_CONFIDENCE=0.6
CORTEX__PROVIDERS__EXTRACTION__TIMEOUT_SECONDS=30

# Anthropic key is optional in MVP (used in follow-ups for intent + generation).
# ANTHROPIC_API_KEY=

# --- Service URLs (compose-internal) ---------------------------------------
CORTEX__PIPELINE__URL=http://pipeline:8000
CORTEX__MCP__PORT=8080
CORTEX__ADMIN_UI__URL=http://admin-ui:3000

# --- Observability ----------------------------------------------------------
# The dev compose profile includes an OTLP/HTTP collector on this hostname.
# Set to `none` only for an explicit offline run; smoke will visibly skip its
# trace assertions in that mode.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAMESPACE=cortex
# OTEL_LOG_LEVEL=debug

# --- Smoke test -------------------------------------------------------------
# Default smoke uses the local deterministic chat stub and finishes within
# five minutes on an already-built healthy stack.
# SMOKE_CHAT_MODE=stub
# SMOKE_TIMEOUT_SECONDS=300
# Set SMOKE_CHAT_MODE=cloud only for the opt-in one-document/two-chunk canary.

# --- Retrieval defaults -----------------------------------------------------
CORTEX__RETRIEVAL__DEFAULT_TOP_K=20
CORTEX__RETRIEVAL__DEFAULT_TOKEN_BUDGET=4000
